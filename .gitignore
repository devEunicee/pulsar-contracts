# Rust build artifacts
/target

# Backup files
**/*.rs.bk

# WASM build artifacts (generated, not source)
*.wasm

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Soroban / Stellar CLI local state
.soroban/

# Node service artifacts
/services/*/node_modules
/services/*/dist

# NOTE: Cargo.lock is intentionally committed for contract crates
# to ensure reproducible builds.

# Environment secret files (NEVER commit these)
.env
.env.*
!.env.example
node_modules/
