CONTRACT_ID=
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
SOURCE_SECRET_KEY=
PORT=3000

# JWT Authentication (Issue #309) — RS256 key pair
# Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
#   openssl rsa -in private.pem -pubout -out public.pem
# Then set the PEM content (with literal \n for newlines) in the variables below.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
